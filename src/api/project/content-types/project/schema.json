{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "liveUrl": {
      "type": "string"
    },
    "githubUrl": {
      "type": "string"
    },
    "date": {
      "type": "date"
    },
    "teamSize": {
      "type": "integer"
    },
    "stars": {
      "type": "integer"
    },
    "forks": {
      "type": "integer"
    },
    "tags": {
      "type": "component",
      "component": "shared.tags",
      "repeatable": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "content": {
      "type": "blocks"
    }
  }
}
